# ── Servidor ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Nível mínimo de log exibido (debug | info | warn | error)
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────
# Origins autorizadas a chamar a API (CORS), separadas por vírgula — sem
# espaço extra necessário, mas tolerado. Ex.: ambiente local + produção:
# FRONTEND_URLS=http://localhost:5173,https://cofre-orcin.vercel.app
FRONTEND_URLS=http://localhost:5173

# ── Banco de dados ────────────────────────────────────────────────────────
# Caminho do arquivo SQLite. Relativo à raiz do backend.
DATABASE_PATH=./src/database/cofre.db

# ── Autenticação Google OAuth (etapa futura) ─────────────────────────────
# Client ID/Secret gerados no Google Cloud Console para o login com Google.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Segredo usado para assinar o cookie de sessão (HTTP-only) do usuário
# autenticado. Gerar um valor aleatório longo antes de usar em produção.
# SESSION_SECRET=

# ── Integração Google Sheets (etapa futura) ──────────────────────────────
# ID da planilha do Google Sheets que o Cofre irá sincronizar.
# GOOGLE_SHEETS_ID=
